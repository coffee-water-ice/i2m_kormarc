# i2m_kormarc 환경변수 템플릿 — 실제 값을 채운 뒤 ".env"로 복사해서 쓸 것.
# .env는 .gitignore에 반드시 포함되어야 한다 (커밋 금지).

# ── 알라딘 Open API ──────────────────────────────────────────
ALADIN_TTB_KEY=
ALADIN_TTB_KEY2=
ALADIN_TTB_KEY3=

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=
# 041/245/300/653 필드별 모델은 core/config.py의 기본값을 따르며,
# 필요할 때만 아래 주석을 해제해 오버라이드한다.
# OPENAI_MODEL_041=gpt-4o
# OPENAI_MODEL_245=gpt-4o
# OPENAI_MODEL_300=gpt-4o-mini
# OPENAI_MODEL_653=gpt-4o

# ── KPIPA 출판유통통합전산망 OpenAPI ──────────────────────────
KPIPA_API_KEY=

# ── 행정안전부(MOIS) 출판사 조회 (공공데이터포털) ─────────────
DATA_GO_KR=

# ── 국립중앙도서관(NLK) — 245/653 스텁 이식 후 사용 ───────────
NLK_CERT_KEY=

# ── 네이버 검색 API (300 책소개 보강) ─────────────────────────
NAVER_SEARCH_KEY_ID=
NAVER_SEARCH_KEY_SECRET=

# ── Google Sheets (출판사 DB, 653 골든데이터) ─────────────────
# 서비스 계정 JSON 전체를 한 줄 문자열로 (private_key의 줄바꿈은 \n으로 이스케이프)
GSPREAD_CREDENTIALS=

# ── 피드백 DB ──────────────────────────────────────────────
FEEDBACK_DB_PATH=./feedback.db
